<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zabguzxcoop.chatbotllm.TranslateDialogController"
      style="-fx-padding: 20px;">

    <Label fx:id="fileNameLabel" text="Файл: " style="-fx-font-weight: bold;"/>

    <Label text="Исходный язык:"/>
    <TextField fx:id="sourceLangField" text="Russian" promptText="Например: Russian"/>

    <Label text="Целевой язык:"/>
    <TextField fx:id="targetLangField" text="English" promptText="Например: English"/>

    <VBox.margin>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </VBox.margin>

</VBox>