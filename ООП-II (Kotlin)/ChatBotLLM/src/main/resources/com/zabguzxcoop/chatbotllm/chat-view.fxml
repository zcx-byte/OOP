<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zabguzxcoop.chatbotllm.ChatController">

    <top>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="Перевести файл" onAction="#handleTranslateFile"
                    style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-padding: 8 16px;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" vbarPolicy="ALWAYS">
            <VBox fx:id="chatArea" spacing="10">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <TextField fx:id="messageField" promptText="Введите сообщение..."
                       HBox.hgrow="ALWAYS" prefHeight="40"/>
            <Button fx:id="sendButton" text="Отправить" onAction="#handleSendButton"
                    prefWidth="100" prefHeight="40"/>
        </HBox>
    </bottom>

</BorderPane>