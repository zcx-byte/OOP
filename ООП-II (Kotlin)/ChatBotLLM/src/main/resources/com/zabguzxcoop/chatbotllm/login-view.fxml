<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zabguzxcoop.chatbotllm.LoginController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="ChatBot LLM" style="-fx-font-size: 32px; -fx-font-weight: bold;"/>
    <Label text="Введите ваше имя:" style="-fx-font-size: 16px;"/>

    <TextField fx:id="usernameField" promptText="Ваше имя" prefWidth="300" prefHeight="40"/>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="loginButton" text="Войти" onAction="#handleLogin" prefWidth="150" prefHeight="40"/>
    </HBox>

</VBox>