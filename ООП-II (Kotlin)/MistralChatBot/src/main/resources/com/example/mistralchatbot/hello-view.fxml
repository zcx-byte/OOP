<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.mistralchatbot.ChatController"
      style="-fx-background-color: white;">

    <Label fx:id="userLabel" text="Пользователь"
           style="-fx-font-size: 14px; -fx-padding: 10; -fx-background-color: #f0f0f0;"/>

    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: white;">
        <VBox fx:id="messagesContainer" spacing="5" style="-fx-padding: 10;"/>
    </ScrollPane>

    <HBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f5f5f5;">
        <TextField fx:id="messageField" promptText="Сообщение..." HBox.hgrow="ALWAYS"
                   onAction="#handleSendButton"/>
        <Button text="Отправить" fx:id="sendButton" onAction="#handleSendButton"/>
    </HBox>

</VBox>